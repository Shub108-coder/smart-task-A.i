<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mentor Dashboard — Smart Task Manager</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f0f13;
      --surface: #16161d;
      --surface2: #1e1e28;
      --border: rgba(255,255,255,0.07);
      --accent: #7B6EF6;
      --accent2: #4ECDC4;
      --danger: #FF6B6B;
      --warning: #FFD93D;
      --success: #6BCB77;
      --text: #f0f0f5;
      --muted: #6b6b80;
      --font-head: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'DM Mono', monospace;
    }

    body { font-family: var(--font-body); background: var(--bg); color: var(--text); min-height: 100vh; }

    /* ── NAVBAR ── */
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem; height: 58px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 100;
    }
    .nav-brand { display: flex; align-items: center; gap: 10px; font-family: var(--font-head); font-weight: 700; font-size: 15px; color: var(--text); text-decoration: none; }
    .nav-logo { width: 30px; height: 30px; background: var(--accent); border-radius: 8px; display: grid; grid-template-columns: 1fr 1fr; gap: 3px; padding: 6px; }
    .nav-logo span { background: rgba(255,255,255,0.9); border-radius: 2px; }
    .nav-logo span:last-child { opacity: 0.4; }
    .nav-links { display: flex; align-items: center; gap: 2px; }
    .nav-link { padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; color: var(--muted); text-decoration: none; transition: all 0.15s; }
    .nav-link:hover { background: var(--surface2); color: var(--text); }
    .nav-link.active { background: rgba(123,110,246,0.15); color: var(--accent); }
    .nav-right { display: flex; align-items: center; gap: 12px; }
    .nav-user { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); }
    .nav-avatar { width: 30px; height: 30px; background: linear-gradient(135deg, var(--accent), var(--accent2)); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: #fff; }
    .nav-logout { padding: 5px 12px; border-radius: 7px; border: 1px solid var(--border); color: var(--muted); font-size: 12px; text-decoration: none; transition: all 0.15s; }
    .nav-logout:hover { border-color: var(--danger); color: var(--danger); }

    /* ── LAYOUT ── */
    .page { padding: 2rem; max-width: 1280px; margin: 0 auto; }

    /* ── HEADER ── */
    .page-header { margin-bottom: 2rem; display: flex; align-items: flex-end; justify-content: space-between; }
    .page-title { font-family: var(--font-head); font-size: 28px; font-weight: 700; color: var(--text); }
    .page-sub { font-size: 13px; color: var(--muted); margin-top: 4px; }
    .header-badge { background: rgba(123,110,246,0.15); border: 1px solid rgba(123,110,246,0.3); color: var(--accent); font-size: 12px; font-weight: 500; padding: 4px 12px; border-radius: 99px; font-family: var(--font-mono); }

    /* ── ALERT BANNER ── */
    .alert-banner {
      background: rgba(255,107,107,0.08);
      border: 1px solid rgba(255,107,107,0.25);
      border-radius: 10px;
      padding: 12px 16px;
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 1.5rem;
      font-size: 13px; color: #FF9999;
    }
    .alert-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--danger); animation: pulse 2s infinite; flex-shrink: 0; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.3)} }

    /* ── STAT CARDS ── */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.25rem;
      position: relative;
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .stat-card:hover { border-color: rgba(123,110,246,0.3); }
    .stat-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--card-accent, var(--accent)); border-radius: 14px 14px 0 0; }
    .stat-card.danger { --card-accent: var(--danger); }
    .stat-card.success { --card-accent: var(--success); }
    .stat-card.warning { --card-accent: var(--warning); }
    .stat-label { font-size: 11px; font-weight: 500; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; }
    .stat-value { font-family: var(--font-head); font-size: 36px; font-weight: 700; line-height: 1; color: var(--text); }
    .stat-value.danger { color: var(--danger); }
    .stat-value.success { color: var(--success); }
    .stat-value.warning { color: var(--warning); }
    .stat-value.accent { color: var(--accent); }
    .stat-sub { font-size: 11px; color: var(--muted); margin-top: 8px; }

    /* ── GRID ── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }
    .grid-3-1 { display: grid; grid-template-columns: 2fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }

    /* ── SECTION CARD ── */
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 1.5rem; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
    .card-title { font-family: var(--font-head); font-size: 15px; font-weight: 600; color: var(--text); }
    .card-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .card-badge { font-size: 11px; font-family: var(--font-mono); padding: 3px 10px; border-radius: 99px; }
    .card-badge.danger { background: rgba(255,107,107,0.12); color: var(--danger); }
    .card-badge.success { background: rgba(107,203,119,0.12); color: var(--success); }
    .card-badge.accent { background: rgba(123,110,246,0.12); color: var(--accent); }

    /* ── TABLE ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th { padding: 8px 12px; text-align: left; font-size: 10px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.07em; border-bottom: 1px solid var(--border); white-space: nowrap; }
    tbody td { padding: 11px 12px; border-bottom: 1px solid rgba(255,255,255,0.03); vertical-align: middle; color: var(--text); }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr { transition: background 0.1s; }
    tbody tr:hover { background: rgba(255,255,255,0.02); }
    tbody tr.row-danger td:first-child { border-left: 2px solid var(--danger); padding-left: 10px; }
    tbody tr.row-warn td:first-child { border-left: 2px solid var(--warning); padding-left: 10px; }
    tbody tr.row-ok td:first-child { border-left: 2px solid var(--success); padding-left: 10px; }

    /* ── BADGES ── */
    .badge { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 500; padding: 3px 9px; border-radius: 99px; white-space: nowrap; }
    .badge-high { background: rgba(255,107,107,0.12); color: #FF9999; }
    .badge-medium { background: rgba(255,217,61,0.12); color: #FFE066; }
    .badge-low { background: rgba(107,203,119,0.12); color: #8DD994; }
    .badge-pending { background: rgba(107,107,128,0.15); color: var(--muted); }
    .badge-progress { background: rgba(123,110,246,0.12); color: var(--accent); }
    .badge-done { background: rgba(107,203,119,0.12); color: var(--success); }
    .badge-score { background: rgba(78,205,196,0.12); color: var(--accent2); font-family: var(--font-mono); font-size: 12px; }

    /* ── BUTTONS ── */
    .btn { display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; border-radius: 7px; font-size: 12px; font-weight: 500; font-family: var(--font-body); cursor: pointer; border: 1px solid var(--border); text-decoration: none; transition: all 0.15s; color: var(--muted); background: transparent; }
    .btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(123,110,246,0.08); }
    .btn-sm { padding: 4px 10px; font-size: 11px; }

    /* ── WORKLOAD BARS ── */
    .workload-list { display: flex; flex-direction: column; gap: 14px; }
    .workload-item { display: flex; align-items: center; gap: 12px; }
    .workload-name { font-size: 13px; color: var(--text); width: 120px; flex-shrink: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .workload-bar-wrap { flex: 1; height: 8px; background: var(--surface2); border-radius: 99px; overflow: hidden; }
    .workload-bar { height: 100%; border-radius: 99px; transition: width 0.8s cubic-bezier(.4,0,.2,1); }
    .workload-bar.ok { background: var(--success); }
    .workload-bar.warn { background: var(--warning); }
    .workload-bar.over { background: var(--danger); }
    .workload-hrs { font-size: 12px; font-family: var(--font-mono); color: var(--muted); width: 40px; text-align: right; flex-shrink: 0; }

    /* ── BOTTLENECK PANEL ── */
    .bottleneck-list { display: flex; flex-direction: column; gap: 0; }
    .bottleneck-item { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
    .bottleneck-item:last-child { border-bottom: none; }
    .bottleneck-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--danger); flex-shrink: 0; }
    .bottleneck-name { flex: 1; color: var(--text); }
    .bottleneck-who { font-size: 11px; color: var(--muted); }

    /* ── CHART ── */
    .chart-wrap { position: relative; height: 200px; }

    /* ── EMPTY ── */
    .empty { text-align: center; padding: 2.5rem 1rem; color: var(--muted); font-size: 13px; }

    /* ── ANIMATIONS ── */
    .fade-in { animation: fadeIn 0.4s ease both; }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .fade-in:nth-child(1){animation-delay:.05s}
    .fade-in:nth-child(2){animation-delay:.1s}
    .fade-in:nth-child(3){animation-delay:.15s}
    .fade-in:nth-child(4){animation-delay:.2s}

    @media(max-width:900px){
      .stats-grid{grid-template-columns:1fr 1fr;}
      .grid-2,.grid-3-1{grid-template-columns:1fr;}
    }
    @media(max-width:540px){
      .stats-grid{grid-template-columns:1fr;}
      .page{padding:1rem;}
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="nav-brand">
    <div class="nav-logo"><span></span><span></span><span></span><span></span></div>
    SmartTask AI
  </a>
  <div class="nav-links">
    <a href="/mentor/dashboard" class="nav-link active">Dashboard</a>
    <a href="/mentor/tasks"     class="nav-link">Team Tasks</a>
    <a href="/mentor/workload"  class="nav-link">Workload</a>
  </div>
  <div class="nav-right">
    <div class="nav-user">
      <div class="nav-avatar">FM</div>
      <span><%= locals.userName || 'Faculty Mentor' %></span>
    </div>
    <a href="/logout" class="nav-logout">Logout</a>
  </div>
</nav>

<%
  const tasks      = locals.tasks   || [];
  const members    = locals.members || [];
  const now        = new Date();
  const overdue    = tasks.filter(t => t.status !== 'Completed' && new Date(t.deadline) < now);
  const completed  = tasks.filter(t => t.status === 'Completed');
  const bottlenecks = tasks.filter(t => t.impact == 3 && t.status === 'Pending');
%>

<div class="page">

  <% if (overdue.length > 0) { %>
  <div class="alert-banner fade-in">
    <div class="alert-dot"></div>
    <strong><%= overdue.length %></strong>&nbsp;team task<%= overdue.length > 1 ? 's are' : ' is' %> overdue — review and reassign if needed.
  </div>
  <% } %>

  <div class="page-header">
    <div>
      <div class="page-title">Team Dashboard</div>
      <div class="page-sub">Monitor workload, priorities and team performance</div>
    </div>
    <div class="header-badge">Faculty Mentor</div>
  </div>

  <div class="stats-grid">
    <div class="stat-card fade-in">
      <div class="stat-label">Total tasks</div>
      <div class="stat-value accent"><%= tasks.length %></div>
      <div class="stat-sub">across all members</div>
    </div>
    <div class="stat-card success fade-in">
      <div class="stat-label">Completed</div>
      <div class="stat-value success"><%= completed.length %></div>
      <div class="stat-sub"><%= tasks.length > 0 ? Math.round((completed.length/tasks.length)*100) : 0 %>% completion rate</div>
    </div>
    <div class="stat-card danger fade-in">
      <div class="stat-label">Overdue</div>
      <div class="stat-value danger"><%= overdue.length %></div>
      <div class="stat-sub">needs immediate attention</div>
    </div>
    <div class="stat-card warning fade-in">
      <div class="stat-label">Team members</div>
      <div class="stat-value warning"><%= members.length %></div>
      <div class="stat-sub">active this week</div>
    </div>
  </div>

  <div class="grid-3-1">
    <div class="card">
      <div class="card-header">
        <div>
          <div class="card-title">Team Task Overview</div>
          <div class="card-sub">All tasks sorted by priority score</div>
        </div>
        <span class="card-badge <%= overdue.length > 0 ? 'danger' : 'success' %>">
          <%= overdue.length > 0 ? overdue.length + ' overdue' : 'All on track' %>
        </span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Member</th>
              <th>Task</th>
              <th>Score</th>
              <th>Deadline</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (tasks.length === 0) { %>
              <tr><td colspan="6" class="empty">No tasks yet</td></tr>
            <% } %>
            <% tasks.forEach(task => {
              const dl = new Date(task.deadline);
              const diffMs = dl - now;
              const diffHrs = diffMs / (1000*60*60);
              const isOverdue = diffMs < 0 && task.status !== 'Completed';
              const isDueSoon = diffHrs >= 0 && diffHrs <= 24;
              const rowClass = isOverdue ? 'row-danger' : isDueSoon ? 'row-warn' : 'row-ok';
              const dlStr = dl.toLocaleDateString('en-IN', { day:'numeric', month:'short' });
            %>
            <tr class="<%= rowClass %>">
              <td style="font-weight:500;"><%= task.memberName || task.userId?.name || '—' %></td>
              <td style="color:var(--muted);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= task.title %></td>
              <td><span class="badge badge-score"><%= task.priorityScore || 0 %></span></td>
              <td style="font-family:var(--font-mono);font-size:12px;color:<%= isOverdue ? 'var(--danger)' : isDueSoon ? 'var(--warning)' : 'var(--muted)' %>"><%= dlStr %></td>
              <td>
                <% if (task.status === 'Completed') { %><span class="badge badge-done">Done</span>
                <% } else if (task.status === 'In Progress') { %><span class="badge badge-progress">In Progress</span>
                <% } else { %><span class="badge badge-pending">Pending</span><% } %>
              </td>
              <td><a href="/mentor/tasks/<%= task._id %>/edit" class="btn btn-sm">Edit</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:1.25rem;">
      <div class="card">
        <div class="card-header">
          <div class="card-title">Workload</div>
          <div class="card-sub">Effort hrs / member</div>
        </div>
        <div class="workload-list">
          <% if (members.length === 0) { %>
            <div class="empty">No members</div>
          <% } %>
          <% members.forEach(m => {
            const hrs = tasks.filter(t => String(t.userId) === String(m._id) && t.status !== 'Completed').reduce((s,t) => s+(t.effort||0), 0);
            const pct = Math.min(100, (hrs/20)*100);
            const barClass = hrs > 20 ? 'over' : hrs > 12 ? 'warn' : 'ok';
          %>
          <div class="workload-item">
            <div class="workload-name"><%= m.name %></div>
            <div class="workload-bar-wrap">
              <div class="workload-bar <%= barClass %>" style="width:<%= pct %>%"></div>
            </div>
            <div class="workload-hrs"><%= hrs %>h</div>
          </div>
          <% }) %>
        </div>
      </div>

      <% if (bottlenecks.length > 0) { %>
      <div class="card">
        <div class="card-header">
          <div class="card-title">Bottlenecks</div>
          <span class="card-badge danger"><%= bottlenecks.length %> blocked</span>
        </div>
        <div class="bottleneck-list">
          <% bottlenecks.slice(0,4).forEach(t => { %>
          <div class="bottleneck-item">
            <div class="bottleneck-dot"></div>
            <div class="bottleneck-name"><%= t.title %></div>
            <div class="bottleneck-who"><%= t.memberName || '—' %></div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div>
        <div class="card-title">Task completion trend</div>
        <div class="card-sub">Last 7 days</div>
      </div>
    </div>
    <div class="chart-wrap">
      <canvas id="trendChart"></canvas>
    </div>
  </div>

</div>

<script>
const trendData = <%- JSON.stringify(locals.trendData || { labels:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'], data:[0,0,0,0,0,0,0] }) %>;
Chart.defaults.color = '#6b6b80';
Chart.defaults.font.family = "'DM Sans', sans-serif";
new Chart(document.getElementById('trendChart'), {
  type: 'line',
  data: {
    labels: trendData.labels,
    datasets: [{
      data: trendData.data,
      borderColor: '#7B6EF6',
      backgroundColor: 'rgba(123,110,246,0.06)',
      fill: true, tension: 0.4,
      pointBackgroundColor: '#7B6EF6',
      pointRadius: 4, borderWidth: 2,
    }]
  },
  options: {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { display: false } },
    scales: {
      y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { display: false } },
      x: { grid: { display: false }, border: { display: false } }
    }
  }
});
</script>
</body>
</html>
