<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Smart Task Manager</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="h-[100vh] w-[100vw] bg-[#2B54D0] flex justify-center items-center">

    <form action="/Login" method="POST" class="bg-white gap-6 rounded-lg flex-col flex justify-center items-center w-[27rem] py-12 px-8">

        <h1 class="text-4xl font-bold text-gray-800">Log in</h1>

        <%# ── ERROR ALERT ── %>
        <% if (locals.error) { %>
        <div class="w-full bg-red-50 border border-red-200 rounded-lg px-4 py-3 flex items-start gap-3">
            <span class="text-red-500 text-lg mt-0.5">✕</span>
            <div>
                <p class="text-red-700 font-semibold text-sm">Login failed</p>
                <p class="text-red-600 text-sm"><%= error %></p>
            </div>
        </div>
        <% } %>

        <%# ── SUCCESS ALERT (optional, for flash messages) ── %>
        <% if (locals.success) { %>
        <div class="w-full bg-green-50 border border-green-200 rounded-lg px-4 py-3 flex items-start gap-3">
            <span class="text-green-500 text-lg mt-0.5">✓</span>
            <div>
                <p class="text-green-700 font-semibold text-sm">Success</p>
                <p class="text-green-600 text-sm"><%= success %></p>
            </div>
        </div>
        <% } %>

        <div class="flex justify-center items-center flex-col w-full gap-3">
            <input
                placeholder="Email"
                class="border border-gray-300 rounded-lg p-3 w-[80%] focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
                type="email"
                name="email"
                required
                value="<%= locals.email || '' %>"
            />
            <input
                placeholder="Password"
                class="border border-gray-300 rounded-lg p-3 w-[80%] focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
                type="password"
                name="password"
                required
            />
        </div>

        <button
            type="submit"
            class="bg-blue-500 hover:bg-blue-600 active:scale-95 transition-all text-white font-bold p-3 w-[10rem] text-xl rounded-lg"
        >
            Log in
        </button>

        <div class="flex gap-4 text-xs text-gray-400">
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-blue-400 inline-block"></span>Team Member</span>
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>Faculty Mentor</span>
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-purple-400 inline-block"></span>Subject Teacher</span>
        </div>

    </form>

</body>
</html>
